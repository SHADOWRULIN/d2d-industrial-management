**/node_modules/
# --- PYTHON & FLASK (V1 & V2 Backend) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt
instance/
.webassets-cache
.env

# --- NODE.JS & REACT (V2 Frontend) ---
v2-web-production/client/node_modules/
v2-web-production/client/build/
v2-web-production/client/.env.local
v2-web-production/client/.env.development.local
v2-web-production/client/.env.test.local
v2-web-production/client/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- DATABASE & GENERATED ARTIFACTS ---
*.db
*.db-journal
v1-desktop-prototype/database/project_database.db
v2-web-production/server/database/project_database.db

# Ignore generated invoices or PDFs
**/invoices/*.pdf
v1-desktop-prototype/database/invoices/

# Ensure everything in the docs folder is tracked, even if it's a PDF
!docs/**/*.pdf
!docs/**/*.png

# --- IDE & SYSTEM FILES ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
